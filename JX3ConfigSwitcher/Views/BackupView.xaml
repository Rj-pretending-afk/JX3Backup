<UserControl x:Class="JX3ConfigSwitcher.Views.BackupView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Foreground="#E8EEF8"
        FontFamily="Microsoft YaHei UI, Segoe UI, Arial"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="ClearType">
    <UserControl.Resources>
        <SolidColorBrush x:Key="AppBackground" Color="#111821"/>
        <SolidColorBrush x:Key="PanelBrush" Color="#CC1A232D"/>
        <SolidColorBrush x:Key="PanelAltBrush" Color="#B8151D26"/>
        <SolidColorBrush x:Key="InputBrush" Color="#CC101720"/>
        <SolidColorBrush x:Key="InputHoverBrush" Color="#D61D2C3A"/>
        <SolidColorBrush x:Key="LineBrush" Color="#2F4658"/>
        <SolidColorBrush x:Key="LineStrongBrush" Color="#48667A"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#6ED7FF"/>
        <SolidColorBrush x:Key="AccentTextBrush" Color="#071018"/>
        <SolidColorBrush x:Key="AccentSoftBrush" Color="#18384A"/>
        <SolidColorBrush x:Key="DangerBrush" Color="#F05D6A"/>
        <SolidColorBrush x:Key="DangerSoftBrush" Color="#4A1E28"/>
        <SolidColorBrush x:Key="TextBrush" Color="#E8EEF8"/>
        <SolidColorBrush x:Key="MutedBrush" Color="#99A6BA"/>
        <SolidColorBrush x:Key="SubtleBrush" Color="#6F7D91"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#6ED7FF"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#071018"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#18384A"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="#FFFFFF"/>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="FontFamily" Value="Microsoft YaHei UI, Segoe UI, Arial"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#FFFFFF" BlurRadius="1.35" ShadowDepth="0" Opacity="0.28"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="0"/>
            <Setter Property="Padding" Value="18"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000000" BlurRadius="16" ShadowDepth="4" Opacity="0.32"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#FFFFFF" BlurRadius="2.2" ShadowDepth="0" Opacity="0.38"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MutedText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Background" Value="{StaticResource PanelAltBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource LineStrongBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="MinHeight" Value="40"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="0">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource InputHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource AccentSoftBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
        </Style>

        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource DangerSoftBrush}"/>
            <Setter Property="BorderBrush" Value="#8A3541"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource InputBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource LineStrongBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="CaretBrush" Value="{StaticResource AccentBrush}"/>
            <Setter Property="MinHeight" Value="40"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="0">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource InputHoverBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="{StaticResource InputBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource LineStrongBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="MinHeight" Value="40"/>
            <Setter Property="Padding" Value="8,4"/>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Background" Value="{StaticResource PanelBrush}"/>
            <Setter Property="Padding" Value="10,7"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource InputHoverBrush}"/>
                    <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource AccentSoftBrush}"/>
                    <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SectComboBoxItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Background" Value="{StaticResource PanelBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Root"
                                Margin="4,3"
                                Padding="10,8"
                                Background="{Binding Color}"
                                BorderBrush="{StaticResource LineBrush}"
                                BorderThickness="1"
                                CornerRadius="0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="4"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Background="{Binding ContrastText}" CornerRadius="0" Opacity="0.5"/>
                                <TextBlock Grid.Column="2"
                                           Text="{Binding DisplayName}"
                                           Foreground="{Binding ContrastText}"
                                           FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="#FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="#FFFFFF"/>
                                <Setter TargetName="Root" Property="BorderThickness" Value="2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SectComboBoxStyle" TargetType="ComboBox">
            <Setter Property="MinHeight" Value="40"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource SectComboBoxItemStyle}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="Toggle"
                                          Focusable="False"
                                          ClickMode="Press"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="SelectionRoot"
                                                MinHeight="40"
                                                Background="{Binding SelectedItem.Color, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                BorderBrush="{StaticResource LineStrongBrush}"
                                                BorderThickness="1"
                                                CornerRadius="0"
                                                Padding="12,8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="24"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding SelectedItem.DisplayName, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                           Foreground="{Binding SelectedItem.ContrastText, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                           FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Grid.Column="1"
                                                           Text="v"
                                                           HorizontalAlignment="Center"
                                                           Foreground="{Binding SelectedItem.ContrastText, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                           FontWeight="Bold"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="SelectionRoot" Property="BorderBrush" Value="#FFFFFF"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Popup x:Name="PART_Popup"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Fade"
                                   IsOpen="{TemplateBinding IsDropDownOpen}">
                                <Border MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        MaxHeight="340"
                                        Background="{StaticResource PanelBrush}"
                                        BorderBrush="{StaticResource LineStrongBrush}"
                                        BorderThickness="1"
                                        CornerRadius="0"
                                        Padding="4">
                                    <ScrollViewer CanContentScroll="True">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,5"/>
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        </Style>

        <Style TargetType="ListBoxItem">
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Root"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                CornerRadius="0"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource InputHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource AccentSoftBrush}"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="RowHeight" Value="38"/>
            <Setter Property="ColumnHeaderHeight" Value="38"/>
            <Setter Property="RowBackground" Value="Transparent"/>
            <Setter Property="AlternatingRowBackground" Value="#181A22"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{StaticResource PanelAltBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource InputHoverBrush}"/>
                    <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource AccentSoftBrush}"/>
                    <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,0"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <DataTemplate x:Key="ProfileTemplate">
            <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
        </DataTemplate>

        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Background" Value="{StaticResource PanelAltBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="18,10"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="0"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header">
                                <ContentPresenter.Effect>
                                    <DropShadowEffect Color="#FFFFFF" BlurRadius="2.4" ShadowDepth="0" Opacity="0.42"/>
                                </ContentPresenter.Effect>
                            </ContentPresenter>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource AccentSoftBrush}"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="{StaticResource AppBackground}" Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0"
                    Panel.ZIndex="5"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="0,0,4,0">
            <TextBlock Text="Profile"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0"
                       Foreground="{StaticResource MutedBrush}"
                       FontWeight="SemiBold"/>
            <ComboBox Width="150"
                      ItemsSource="{Binding Profiles}"
                      SelectedItem="{Binding SelectedProfile}"
                      ItemTemplate="{StaticResource ProfileTemplate}"/>
        </StackPanel>

        <TabControl Grid.Row="0" Margin="0,0,0,12">
            <TabItem Header="备份 / 历史">
        <Grid Margin="0,14,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="340"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Margin="0,0,12,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="1.25*"/>
                    <RowDefinition Height="1*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Style="{StaticResource Card}" Margin="0,0,0,12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.ColumnSpan="2" Margin="0,0,0,10">
                            <TextBlock Text="游戏路径" Style="{StaticResource SectionTitle}"/>
                            <TextBlock Text="默认扫描所有盘符下的 X:\JX3，并自动定位 userdata。"
                                       Margin="0,3,0,0"
                                       FontSize="12"
                                       Style="{StaticResource MutedText}"/>
                        </StackPanel>
                        <TextBox Grid.Row="1"
                                 Text="{Binding GamePath, UpdateSourceTrigger=PropertyChanged}"
                                 VerticalAlignment="Center"/>
                        <StackPanel Grid.Row="1" Grid.Column="1"
                                    Orientation="Horizontal"
                                    Margin="12,0,0,0">
                            <Button Content="选择"
                                    Command="{Binding ChooseGamePathCommand}"
                                    Margin="0,0,8,0"/>
                            <Button Content="扫描"
                                    Command="{Binding ScanGamePathsCommand}"
                                    Style="{StaticResource PrimaryButton}"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,0,0,12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <DockPanel Margin="0,0,0,10">
                            <CheckBox DockPanel.Dock="Right"
                                      IsChecked="{Binding ShowCurrentProfileOnly}"
                                      Content="只看当前 Profile 已分配角色"
                                      Foreground="{StaticResource TextBrush}"
                                      VerticalAlignment="Center"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="角色列表" Style="{StaticResource SectionTitle}"/>
                                <TextBlock Text="{Binding Characters.Count, StringFormat={}{0} 个角色}"
                                           Margin="6,4,0,0"
                                           Style="{StaticResource MutedText}"/>
                            </StackPanel>
                        </DockPanel>
                        <Border Grid.Row="1"
                                Background="{StaticResource InputBrush}"
                                BorderBrush="{StaticResource LineBrush}"
                                BorderThickness="1"
                                CornerRadius="0">
                            <DataGrid ItemsSource="{Binding Characters}"
                                      SelectedItem="{Binding SelectedCharacter}"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      SelectionMode="Single">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="账号" Binding="{Binding Account}" Width="0.75*"/>
                                    <DataGridTextColumn Header="区服" Binding="{Binding Server}" Width="0.95*"/>
                                    <DataGridTextColumn Header="角色" Binding="{Binding CharacterName}" Width="0.9*"/>
                                    <DataGridTextColumn Header="门派" Binding="{Binding Sect}" Width="0.62*"/>
                                    <DataGridTextColumn Header="心法" Binding="{Binding Kungfu}" Width="0.78*"/>
                                    <DataGridTextColumn Header="装分" Binding="{Binding EquipmentScore}" Width="54"/>
                                    <DataGridTextColumn Header="dump" Binding="{Binding DumpFiles.Count}" Width="50"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>
                    </Grid>
                </Border>

                <Border Grid.Row="2" Style="{StaticResource Card}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock Text="保存档 Slot 01-99" Style="{StaticResource SectionTitle}"/>
                            <TextBlock Text=" 每个用户独立 99 个保存档"
                                       Margin="4,4,0,0"
                                       Style="{StaticResource MutedText}"/>
                        </StackPanel>
                        <ListBox Grid.Row="1"
                                 ItemsSource="{Binding Slots}"
                                 SelectedItem="{Binding SelectedSlot}"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Width="108"
                                            Height="70"
                                            Background="{StaticResource InputBrush}"
                                            BorderBrush="{StaticResource LineBrush}"
                                            BorderThickness="1"
                                            CornerRadius="0"
                                            Padding="10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="4"/>
                                                <ColumnDefinition Width="8"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="28"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Background="{Binding SectColor}" CornerRadius="0"/>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="{Binding NumberText}" FontWeight="Bold"/>
                                                <TextBlock Text="{Binding KindText}" FontSize="11" Foreground="{StaticResource MutedBrush}"/>
                                                <TextBlock Text="{Binding Name}" FontSize="10" Foreground="{StaticResource SubtleBrush}" TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                            <Button Grid.Column="3"
                                                    Content="{Binding FavoriteText}"
                                                    Command="{Binding DataContext.ToggleSlotFavoriteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Padding="0"
                                                    MinHeight="22"
                                                    Height="22"
                                                    Width="24"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>
            </Grid>

            <Border Grid.Column="1" Style="{StaticResource Card}">
                <DockPanel LastChildFill="True">
                    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
                        <TextBlock Text="备份 / 恢复" Style="{StaticResource SectionTitle}"/>
                        <TextBlock Text="保存档是手动长期档位，历史版本跟随当前选中的角色。"
                                   Margin="0,4,0,0"
                                   FontSize="12"
                                   Style="{StaticResource MutedText}"/>
                    </StackPanel>

                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel>
                            <TextBlock Text="保存档名称" Margin="0,0,0,6" Style="{StaticResource MutedText}"/>
                            <TextBox Text="{Binding SlotNameDraft, UpdateSourceTrigger=PropertyChanged}"/>

                            <TextBlock Text="门派/心法标签" Margin="0,12,0,6" Style="{StaticResource MutedText}"/>
                            <ComboBox ItemsSource="{Binding SectOptions}"
                                      SelectedItem="{Binding SelectedSectOption}"
                                      Style="{StaticResource SectComboBoxStyle}"/>
                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Background="{Binding SelectedSectOption.Color}" CornerRadius="0"/>
                                <TextBlock Grid.Column="2"
                                           Text="{Binding SectTagDraft}"
                                           Foreground="{StaticResource MutedBrush}"
                                           TextTrimming="CharacterEllipsis"/>
                            </Grid>

                            <TextBlock Text="备注" Margin="0,12,0,6" Style="{StaticResource MutedText}"/>
                            <TextBox Text="{Binding NoteDraft, UpdateSourceTrigger=PropertyChanged}"
                                     MinHeight="58"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"/>

                            <TextBlock Text="模块选择" Margin="0,16,0,8" FontWeight="SemiBold"/>
                            <ItemsControl ItemsSource="{Binding ModuleChoices}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsSelected}">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Name}">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsHighRisk}" Value="True">
                                                                    <Setter Property="Foreground" Value="{StaticResource DangerBrush}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <TextBlock Text="{Binding Description}"
                                                           FontSize="11"
                                                           Foreground="{StaticResource MutedBrush}"
                                                           TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </CheckBox>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Grid Margin="0,16,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button Content="创建备份"
                                        Command="{Binding CreateBackupCommand}"
                                        Style="{StaticResource PrimaryButton}"
                                        Margin="0,0,6,0"/>
                                <Button Grid.Column="1"
                                        Content="恢复到角色"
                                        Command="{Binding RestoreBackupCommand}"
                                        Style="{StaticResource DangerButton}"
                                        Margin="6,0,0,0"/>
                            </Grid>

                            <Border Background="{StaticResource PanelAltBrush}"
                                    BorderBrush="{StaticResource LineBrush}"
                                    BorderThickness="1"
                                    CornerRadius="0"
                                    Padding="12"
                                    Margin="0,16,0,0">
                                <StackPanel>
                                    <TextBlock Text="当前角色历史版本" FontWeight="Bold"/>
                                    <ListBox Margin="0,8,0,0"
                                             MaxHeight="190"
                                             ItemsSource="{Binding RecentBackups}"
                                             SelectedItem="{Binding SelectedBackup}">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel>
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding Kind}" FontSize="12" FontWeight="SemiBold"/>
                                                        <TextBlock Text="{Binding SlotNumber, StringFormat=  Slot {0:00}}" FontSize="12" Foreground="{StaticResource MutedBrush}"/>
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding ModuleSummary}" FontSize="11" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap"/>
                                                    <TextBlock Text="{Binding CreatedAt}" FontSize="10" Foreground="{StaticResource SubtleBrush}"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                    <Border Margin="0,10,0,0"
                                            Padding="10"
                                            Background="#132235"
                                            BorderBrush="{StaticResource LineBrush}"
                                            BorderThickness="1"
                                            CornerRadius="0">
                                        <TextBlock Text="{Binding RiskSummary}" TextWrapping="Wrap" Foreground="#C7D2E5"/>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <Border Background="{StaticResource PanelAltBrush}"
                                    BorderBrush="{StaticResource LineBrush}"
                                    BorderThickness="1"
                                    CornerRadius="0"
                                    Padding="12"
                                    Margin="0,16,0,0">
                                <StackPanel>
                                    <TextBlock Text="同步与便携数据" FontWeight="Bold"/>
                                    <TextBlock Text="同步文件夹" Margin="0,10,0,6" Style="{StaticResource MutedText}"/>
                                    <TextBox Text="{Binding SyncFolder, UpdateSourceTrigger=PropertyChanged}"/>
                                    <Grid Margin="0,10,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Button Content="选择目录"
                                                Command="{Binding ChooseSyncFolderCommand}"
                                                Margin="0,0,6,0"/>
                                        <Button Grid.Column="1"
                                                Content="同步备份"
                                                Command="{Binding SyncSelectedBackupCommand}"
                                                Margin="6,0,0,0"/>
                                    </Grid>
                                    <Button Content="打开 data 目录"
                                            Margin="0,10,0,0"
                                            Command="{Binding OpenDataFolderCommand}"/>
                                    <TextBlock Text="{Binding DataDirectory}"
                                               Margin="0,8,0,0"
                                               FontSize="11"
                                               Foreground="{StaticResource SubtleBrush}"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>
            </TabItem>

            <TabItem Header="跨角色覆盖">
                <Grid Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="300"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,10,0">
                        <DockPanel LastChildFill="True">
                            <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
                                <TextBlock Text="可拖拽保存档" Style="{StaticResource SectionTitle}"/>
                                <TextBlock Text="同门派/心法的保存档会自动排在前面；收藏的保存档也会出现在下方。"
                                           Margin="0,4,0,0"
                                           FontSize="12"
                                           Style="{StaticResource MutedText}"/>
                            </StackPanel>

                            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                <StackPanel>
                                    <TextBlock Text="匹配 / 全部保存档" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                    <ItemsControl ItemsSource="{Binding CoverSourceSlots}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Width="142"
                                                        Height="88"
                                                        Margin="0,0,10,10"
                                                        Padding="10"
                                                        Background="{StaticResource InputBrush}"
                                                        BorderBrush="{StaticResource LineBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="0"
                                                        MouseMove="SlotCard_MouseMove"
                                                        PreviewMouseLeftButtonDown="SlotCard_PreviewMouseLeftButtonDown">
                                                    <Grid>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="*"/>
                                                            <RowDefinition Height="Auto"/>
                                                        </Grid.RowDefinitions>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="4"/>
                                                            <ColumnDefinition Width="8"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="28"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Border Grid.RowSpan="3" Background="{Binding SectColor}" CornerRadius="0"/>
                                                        <TextBlock Grid.Column="2" Text="{Binding NumberText}" FontWeight="Bold"/>
                                                        <Button Grid.Column="3"
                                                                Content="{Binding FavoriteText}"
                                                                Command="{Binding DataContext.ToggleSlotFavoriteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}"
                                                                Padding="0"
                                                                MinHeight="22"
                                                                Height="22"
                                                                Width="24"/>
                                                        <TextBlock Grid.Row="1" Grid.Column="2" Grid.ColumnSpan="2"
                                                                   Text="{Binding Name}"
                                                                   Foreground="{StaticResource MutedBrush}"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                        <TextBlock Grid.Row="2" Grid.Column="2"
                                                                   Text="{Binding MatchText}"
                                                                   Foreground="{StaticResource AccentBrush}"
                                                                   FontSize="11"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <TextBlock Text="收藏" FontWeight="SemiBold" Margin="0,14,0,8"/>
                                    <ItemsControl ItemsSource="{Binding FavoriteSlots}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Width="142"
                                                        Height="68"
                                                        Margin="0,0,10,10"
                                                        Padding="10"
                                                        Background="{StaticResource PanelAltBrush}"
                                                        BorderBrush="{StaticResource AccentBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="0"
                                                        MouseMove="SlotCard_MouseMove"
                                                        PreviewMouseLeftButtonDown="SlotCard_PreviewMouseLeftButtonDown">
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding NumberText}" FontWeight="Bold"/>
                                                        <TextBlock Text="{Binding Name}" Foreground="{StaticResource MutedBrush}" TextTrimming="CharacterEllipsis"/>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </ScrollViewer>
                        </DockPanel>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource Card}">
                        <DockPanel LastChildFill="True">
                            <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
                                <TextBlock Text="目标角色" Style="{StaticResource SectionTitle}"/>
                                <TextBlock Text="把左侧保存档块拖到任意角色块上。覆盖前会自动备份目标角色；门派不匹配时会提示宏、技能位置和完整 dump 覆盖风险。"
                                           Margin="0,4,0,0"
                                           FontSize="12"
                                           Style="{StaticResource MutedText}"/>
                            </StackPanel>

                            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                <ItemsControl ItemsSource="{Binding Characters}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Width="260"
                                                    Height="118"
                                                    Margin="0,0,12,12"
                                                    Padding="12"
                                                    Background="{StaticResource InputBrush}"
                                                    BorderBrush="{StaticResource LineBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="0"
                                                    AllowDrop="True"
                                                    DragEnter="RoleCard_DragEnter"
                                                    Drop="RoleCard_Drop"
                                                    DragLeave="RoleCard_DragLeave"
                                                    DragOver="RoleCard_DragOver">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding CharacterName}" FontSize="16" FontWeight="Bold"/>
                                                    <TextBlock Text="{Binding Server}" Foreground="{StaticResource MutedBrush}" TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="{Binding SectTag}" Foreground="{StaticResource AccentBrush}" Margin="0,8,0,0" TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="{Binding EquipmentScore, StringFormat=装分 {0}}" Foreground="{StaticResource SubtleBrush}" FontSize="11"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </DockPanel>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>

        <Border Grid.Row="1"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource LineBrush}"
                BorderThickness="1"
                CornerRadius="0"
                Padding="12,8">
            <TextBlock Text="提示：保存档可跨角色覆盖；门派不匹配时会额外提醒宏、技能/动作按钮和完整 dump 的覆盖风险。覆盖前始终会自动备份目标角色。"
                       Foreground="{StaticResource MutedBrush}"
                       TextWrapping="Wrap"/>
        </Border>
    </Grid>
</UserControl>
